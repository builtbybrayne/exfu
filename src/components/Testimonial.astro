---
interface Props {
  quote: string;
  name: string;
  role?: string;
  variant?: 'light' | 'dark';
}

const {
  quote,
  name,
  role,
  variant = 'light',
} = Astro.props;
---

<aside class:list={['testimonial', `testimonial--${variant}`]}>
  <div class="testimonial-inner section-container">
    <blockquote class="testimonial-card reveal">
      <p class="testimonial-quote">{quote}</p>
      <footer class="testimonial-attribution">
        <cite class="testimonial-name">{name}</cite>
        {role && <span class="testimonial-role">{role}</span>}
      </footer>
    </blockquote>
  </div>
</aside>

<style>
  .testimonial {
    padding-block: var(--space-xl);
  }

  .testimonial--light {
    background: var(--color-surface-light);
  }

  .testimonial--dark {
    background: var(--color-surface-dark);
  }

  .testimonial-card {
    max-width: 42rem;
    margin-inline: auto;
    text-align: center;
    padding: var(--space-lg) var(--space-xl);
  }

  .testimonial-quote {
    font-family: var(--font-display);
    font-size: var(--text-body-lg);
    font-weight: 400;
    font-style: italic;
    line-height: 1.7;
    max-width: none;
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-accent);
  }

  .testimonial--light .testimonial-quote {
    color: var(--color-text-light);
  }

  .testimonial--dark .testimonial-quote {
    color: var(--color-text-dark);
  }

  .testimonial-attribution {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .testimonial-name {
    font-family: var(--font-body);
    font-size: var(--text-body);
    font-weight: 500;
    font-style: normal;
  }

  .testimonial--light .testimonial-name {
    color: var(--color-text-light);
  }

  .testimonial--dark .testimonial-name {
    color: var(--color-text-dark);
  }

  .testimonial-role {
    font-family: var(--font-body);
    font-size: var(--text-small);
    color: var(--color-muted);
  }
</style>

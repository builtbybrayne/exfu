---
interface Props {
  term: string;
  pronunciation?: string;
  partOfSpeech?: string;
  definition: string;
  variant?: 'light' | 'dark';
}

const {
  term = 'ExFu',
  pronunciation,
  partOfSpeech,
  definition,
  variant = 'light',
} = Astro.props;
---

<aside class:list={['definition', `definition--${variant}`]} role="note">
  <div class="definition-inner section-container">
    <div class="definition-block reveal">
      <div class="definition-header">
        <span class="definition-term">{term}</span>
        {pronunciation && <span class="definition-pronunciation">{pronunciation}</span>}
        {partOfSpeech && <span class="definition-pos">{partOfSpeech}</span>}
      </div>
      <p class="definition-text" set:html={definition} />
    </div>
  </div>
</aside>

<style>
  .definition {
    padding-block: var(--space-xl);
  }

  .definition--light {
    background: var(--color-surface-light);
  }

  .definition--dark {
    background: var(--color-surface-dark);
  }

  .definition-inner {
    max-width: var(--max-width);
  }

  .definition-block {
    max-width: 36rem;
    margin-left: auto;
    padding: var(--space-lg) var(--space-xl);
    border-left: 2px solid var(--color-accent);
  }

  .definition-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-xs) var(--space-sm);
    margin-bottom: var(--space-xs);
  }

  .definition-term {
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-body-lg);
  }

  .definition--light .definition-term {
    color: var(--color-primary);
  }

  .definition--dark .definition-term {
    color: var(--color-text-dark);
  }

  .definition-pronunciation {
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-weight: 400;
    opacity: 0.5;
  }

  .definition--light .definition-pronunciation {
    color: var(--color-text-light);
  }

  .definition--dark .definition-pronunciation {
    color: var(--color-text-dark);
  }

  .definition-pos {
    font-family: var(--font-body);
    font-size: var(--text-small);
    font-style: italic;
    opacity: 0.5;
  }

  .definition--light .definition-pos {
    color: var(--color-text-light);
  }

  .definition--dark .definition-pos {
    color: var(--color-text-dark);
  }

  .definition-text {
    font-family: var(--font-body);
    font-size: var(--text-body);
    line-height: 1.6;
    max-width: none;
  }

  .definition--light .definition-text {
    color: var(--color-muted);
  }

  .definition--dark .definition-text {
    color: rgba(237, 233, 228, 0.7);
  }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Definition from '../components/Definition.astro';
import Recognition from '../components/Recognition.astro';
import Testimonial from '../components/Testimonial.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Approach from '../components/Approach.astro';
import About from '../components/About.astro';
import Contact from '../components/Contact.astro';
import Lope from '../components/Lope.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Nav />
  <main id="main">
    <section class="intro">
      <div class="intro-inner section-container">
        <h1 class="intro-headline">I set up your AI assistant with you.</h1>
      </div>
    </section>
    <Hero />

    <Definition
      term="ExFu"
      pronunciation="/ˈeks.fuː/"
      partOfSpeech="noun"
      definition='Execution fu. <span style="font-style: italic; opacity: 0.5;">(see Kung Fu)</span><br />The art of making AI work for you.'
      variant="light"
    />

    <Recognition />

    <Testimonial
      quote="Just to say Alastair that I'm having the most amazing experience with Claude, having connected it with OneDrive, Gmail, MailerLite, Wordpress and more... Stunning. Thank you. Game-changer stuff."
      name="Mark"
      role="Company Director"
      variant="light"
    />

    <Definition
      term="ExFu"
      pronunciation="/ˈeks.fuː/"
      partOfSpeech="noun"
      definition="Executive function. The cognitive processes that let you plan, prioritise, start things, and see them through. The thing AI can give you more of."
      variant="dark"
    />

    <HowItWorks />

    <Testimonial
      quote="Thank you very much again for the brilliant sessions. That was very helpful and insightful. Very much looking forward to working more closely with my new buddy Claude."
      name="Julie"
      role="Startup Founder"
      variant="dark"
    />

    <Definition
      term="ExFu"
      pronunciation="/ˈeks.fuː/"
      partOfSpeech="adj."
      definition="Executive, functioning. The version of you that's on top of it. Not because you grew more arms, but because you got smarter tools."
      variant="light"
    />

    <Approach />

    <Testimonial
      quote="I found myself saying 'wow' and 'amazing' more than once throughout our sessions. It was genuine relief. Relief at being truly heard, and at seeing real solutions appear so quickly and effortlessly. He gave me back my time, which is everything to me right now."
      name="Daphne"
      role="Coach & Author"
      variant="light"
    />

    <About />
    <Contact />
    <Lope />
  </main>
  <Footer />
</BaseLayout>

<style>
  .intro {
    background: var(--color-surface-dark);
    padding-top: calc(var(--space-lg) + 60px); /* account for fixed nav */
    padding-bottom: var(--space-md);
  }

  .intro-inner {
    max-width: var(--max-width);
  }

  .intro-headline {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2vw + 0.5rem, 1.75rem);
    font-weight: 400;
    line-height: 1.3;
    color: var(--color-text-dark);
  }
</style>
